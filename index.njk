<!-- Skills Matrix -->
<section class="section">
  <h2 class="section-title">Skills & Expertise</h2>
  <div class="skills-grid">
    <div class="skill-group">
      <h3>Backend / Java</h3>
      <div class="skill-tags">
        <span class="skill-tag">Core Java</span>
        <span class="skill-tag">Java Advanced</span>
        <span class="skill-tag">Spring Boot</span>
        <span class="skill-tag">Spring AI</span>
        <span class="skill-tag">Microservices</span>
        <span class="skill-tag">Design Patterns</span>
      </div>
    </div>
    <div class="skill-group">
      <h3>Frontend / Full-Stack</h3>
      <div class="skill-tags">
        <span class="skill-tag">JavaScript</span>
        <span class="skill-tag">TypeScript</span>
        <span class="skill-tag">Node.js</span>
        <span class="skill-tag">React</span>
      </div>
    </div>
    <div class="skill-group">
      <h3>AI / Automation</h3>
      <div class="skill-tags">
        <span class="skill-tag">Gen AI</span>
        <span class="skill-tag">LLM/RAG</span>
        <span class="skill-tag">Agentic AI</span>
        <span class="skill-tag">Spring AI</span>
        <span class="skill-tag">n8n Workflow</span>
        <span class="skill-tag">AI Agent Creation</span>
        <span class="skill-tag">GitHub Copilot</span>
      </div>
    </div>
    <div class="skill-group">
      <h3>Cloud / DevOps</h3>
      <div class="skill-tags">
        <span class="skill-tag">DevOps</span>
        <span class="skill-tag">Azure Cloud</span>
        <span class="skill-tag">GitHub Actions</span>
        <span class="skill-tag">Docker</span>
        <span class="skill-tag">CI/CD</span>
      </div>
    </div>
  </div>
</section>

<!-- Featured Projects -->
<section class="section">
  <h2 class="section-title">Featured Projects</h2>
  <div class="card-grid">
    {% for project in collections.featuredProjects | limit(3) %}
    <div class="card" data-tags="{{ project.data.tags | join(',') }}">
      <div class="card-meta">
        <time>{{ project.data.date | dateFormat }}</time>
        {% if project.data.status %}
        <span class="status-badge status-{{ project.data.status }}">{{ project.data.status }}</span>
        {% endif %}
      </div>
      <h3><a href="{{ project.url }}">{{ project.data.title }}</a></h3>
      <p>{{ project.data.description }}</p>
      <div class="tag-list">
        {% for tag in project.data.tags %}
        <span class="tag">{{ tag }}</span>
        {% endfor %}
      </div>
    </div>
    {% endfor %}
  </div>
</section>

<!-- Latest Blog Posts -->
<section class="section">
  <h2 class="section-title">Latest Posts</h2>
  <div class="card-grid">
    {% for post in collections.posts | limit(3) %}
    <div class="card">
      <div class="card-meta">
        <time>{{ post.data.date | dateFormat }}</time>
        <span>{{ post.content | readingTime }}</span>
      </div>
      <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
      <p>{{ post.data.description }}</p>
      <div class="tag-list">
        {% for tag in post.data.tags %}
        <span class="tag">{{ tag }}</span>
        {% endfor %}
      </div>
    </div>
    {% endfor %}
  </div>
</section>
